{
  "name": "local-expo-build",
  "version": "0.4.2",
  "description": "One-stop CLI for local Expo builds. Android (stable) → AAB/APK with EAS-synced versionCode and managed signing. iOS (experimental, macOS) → IPA via xcodebuild with auto export-options.plist.",
  "keywords": [
    "expo",
    "android",
    "ios",
    "build",
    "aab",
    "apk",
    "ipa",
    "eas",
    "gradle",
    "xcodebuild",
    "keystore",
    "signing",
    "react-native",
    "cli"
  ],
  "license": "MIT",
  "author": {
    "name": "Nikhil Dhawan",
    "email": "nikhild64@gmail.com"
  },
  "homepage": "https://github.com/nikhild64/local-expo-build#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikhild64/local-expo-build.git"
  },
  "bugs": {
    "url": "https://github.com/nikhild64/local-expo-build/issues"
  },
  "bin": {
    "local-expo-build": "bin/local-expo-build.js"
  },
  "main": "dist/cli.js",
  "files": [
    "bin",
    "dist",
    "templates",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "npm run build && node --test \"test/**/*.test.js\"",
    "test:only": "node --test \"test/**/*.test.js\"",
    "prepublishOnly": "npm run build && node --test \"test/**/*.test.js\"",
    "start": "node bin/local-expo-build.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.1",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "kleur": "^4.1.5",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/semver": "^7.5.8",
    "typescript": "^5.7.2"
  }
}
